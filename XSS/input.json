{
  "base_url": "https://xss-game.appspot.com",
  "spider_urls": [
    "https://xss-game.appspot.com/level1/frame?query=test",
    "https://xss-game.appspot.com/level3/frame#1",
    "https://xss-game.appspot.com/level4/frame?timer=3",
    "https://xss-game.appspot.com/level5/frame/signup?next=confirm"
  ],
  "urls": [
    {
      "url": "https://xss-game.appspot.com/level2/frame",
      "type": "form",
      "method": "GET",
      "params": {
        "content": "test",
        "action": "sign"
      },
      "safe_to_submit": true,
      "source": "xss-game-level2"
    }
  ],
  "options": {
    "browser_verify": true,
    "stored_xss": true,
    "dom_hash_xss": true,
    "dom_stored_xss": true,
    "timeout": 10,
    "verify_tls": false
  }
}
